<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Voice commands (opt-in, push-to-talk only — see VoiceCommandController). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Optional device-location weather lookup (see DeviceLocationProvider). Coarse is enough
         for a city-level forecast. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Weather fetches (Open-Meteo) and connectivity checks. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Lets InstalledAppResolver query launchable apps without QUERY_ALL_PACKAGES. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CALCULATOR" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MESSAGING" />
        </intent>
        <intent>
            <action android:name="android.media.action.STILL_IMAGE_CAMERA" />
        </intent>
    </queries>

</manifest>
